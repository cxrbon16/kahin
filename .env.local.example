# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Comma separated list of admin emails (can enter real results)
ADMIN_EMAILS=korayoray08@gmail.com

# Public site URL (used for magic link redirect). Locally: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Automatic result sync (Dev #2) ---
# Supabase service_role key (Project Settings -> API). SERVER ONLY, keep secret.
# Used by the sync job to write results bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Free token from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=YOUR_FOOTBALL_DATA_TOKEN
# Optional: competition code (default WC = World Cup)
FOOTBALL_DATA_COMPETITION=WC

# Shared secret protecting /api/sync. Vercel Cron sends it automatically.
# Generate any random string, e.g. `openssl rand -hex 24`.
CRON_SECRET=YOUR_RANDOM_SECRET
